{
  "name": "ng-open-icon",
  "version": "0.1.4",
  "description": "Angular component package for rendering Open Icon assets with shared icon lookup helpers.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./static": {
      "types": "./dist/static.d.ts",
      "import": "./dist/static.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm --workspace open-icon run build && npm run clean && ngc -p tsconfig.json",
    "typecheck": "npm --workspace open-icon run build && ngc -p tsconfig.json",
    "test": "npm run build && node --test ./test/*.test.js"
  },
  "keywords": [
    "angular",
    "icons",
    "svg",
    "open-icon"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@angular/core": "^19.0.0 || ^20.0.0",
    "@angular/platform-browser": "^19.0.0 || ^20.0.0",
    "rxjs": "^7.8.0"
  },
  "dependencies": {
    "open-icon": "1.1.3"
  },
  "devDependencies": {
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-server": "^20.0.0",
    "rxjs": "^7.8.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silvandiepen/open-icon-libs.git",
    "directory": "packages/ng-open-icon"
  }
}
