{
  "name": "wc-open-icon",
  "version": "0.1.6",
  "description": "Web component package for rendering Open Icon assets with shared icon lookup helpers.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cdn": {
      "types": "./dist/cdn/index.d.ts",
      "import": "./dist/cdn/index.js"
    },
    "./cdn/auto": {
      "types": "./dist/cdn/auto.d.ts",
      "import": "./dist/cdn/auto.js"
    },
    "./static": {
      "types": "./dist/static.d.ts",
      "import": "./dist/static.js"
    },
    "./auto": {
      "types": "./dist/auto.d.ts",
      "import": "./dist/auto.js"
    },
    "./package.json": "./package.json"
  },
  "unpkg": "./dist/cdn/auto.js",
  "jsdelivr": "./dist/cdn/auto.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm --workspace open-icon run build && npm run clean && tsc -p tsconfig.json",
    "typecheck": "npm --workspace open-icon run build && tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test ./test/*.test.js"
  },
  "keywords": [
    "web-components",
    "custom-elements",
    "icons",
    "svg",
    "open-icon"
  ],
  "license": "MIT",
  "dependencies": {
    "open-icon": "1.1.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silvandiepen/open-icon-libs.git",
    "directory": "packages/wc-open-icon"
  }
}
