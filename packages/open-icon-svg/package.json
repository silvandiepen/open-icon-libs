{
  "name": "open-icon-svg",
  "version": "0.1.3",
  "description": "Open Icon SVG catalog with generated names, types, and lookup metadata.",
  "type": "module",
  "exports": {
    "./icons/*": "./icons/*",
    "./package.json": "./package.json"
  },
  "files": [
    "icons",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node ./scripts/validate-package.mjs",
    "build": "node ./scripts/validate-package.mjs",
    "typecheck": "node ./scripts/validate-package.mjs",
    "test": "node --test ./test/*.test.js"
  },
  "keywords": [
    "svg",
    "icons",
    "open-icon",
    "catalog"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silvandiepen/open-icon-libs.git",
    "directory": "packages/open-icon-svg"
  }
}
