{
  "name": "open-icon-api",
  "private": true,
  "version": "0.1.0",
  "description": "Cloudflare Worker API for open-icon metadata and asset delivery.",
  "type": "module",
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "build:data": "node ./scripts/build-api-assets.mjs",
    "build": "npm run build:data && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test ./test/*.test.js",
    "clean": "rm -rf dist assets/icons src/generated"
  },
  "devDependencies": {
    "wrangler": "^4.10.0"
  },
  "dependencies": {
    "@cf-wasm/resvg": "^0.3.3"
  }
}
